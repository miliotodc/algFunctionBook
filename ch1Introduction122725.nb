Cell["Section 1.2:  Illustrate z^{1/2} ", "Section",
 CellChangeTimes->{{3.975861220271741*^9, 3.9758612333778706`*^9}, {
  3.9758612954505744`*^9, 3.9758613096966743`*^9}, {3.9761759512968507`*^9, 
