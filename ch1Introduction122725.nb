Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"theFunction", "=", 
     RowBox[{
      RowBox[{"-", "z"}], "+", 
      RowBox[{"w", "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{"(*", "  ", 
    RowBox[{"start", " ", "the", " ", "contour", " ", "at", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "/", "2"}], "]"}]}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z0", "=", 
     RowBox[{
      RowBox[{"3", "/", "2"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"Pi", " ", 
        RowBox[{"I", "/", "6"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"w0", "=", 
     RowBox[{"Sqrt", "[", "z0", "]"}]}], ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "rotate", " ", "around", " ", "the", " ", "branch", " ", "sheets", " ", 
     "4", " ", "Pi"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tStart", "=", 
     RowBox[{"Pi", "/", "6"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tEnd", "=", 
     RowBox[{"tStart", "+", 
      RowBox[{"4", " ", "Pi"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", "  ", 
    RowBox[{"create", " ", "z", 
     RowBox[{"(", "t", ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Z", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"3", "/", "2"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "t"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{"(*", "  ", 
    RowBox[{"solve", " ", "mIVP"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wDeriv", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"w", "'"}], "[", "t", "]"}], "==", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{"theFunction", ",", "z"}], "]"}], "/", 
             RowBox[{"D", "[", 
              RowBox[{"theFunction", ",", "w"}], "]"}]}], ")"}]}], " ", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Z", "[", "t", "]"}], ",", "t"}], "]"}]}], ")"}], "/.", 
        " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"w", "->", 
           RowBox[{"w", "[", "t", "]"}]}], ",", 
          RowBox[{"z", "->", 
           RowBox[{"Z", "[", "t", "]"}]}]}], "}"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"imagSol", "=", 
     RowBox[{"NDSolveValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"wDeriv", ",", 
         RowBox[{
          RowBox[{"w", "[", "tStart", "]"}], "==", "w0"}]}], "}"}], ",", "w", 
       ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "tStart", ",", "tEnd"}], "}"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"create", " ", "plot"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"imagContourPlot", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "z"}], ",", 
         RowBox[{"Im", "@", "z"}], ",", 
         RowBox[{"Im", "@", 
          RowBox[{"imagSol", "[", "t", "]"}]}]}], "}"}], "/.", " ", 
       RowBox[{"z", "->", 
        RowBox[{"Z", "[", "t", "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tStart", ",", "tEnd"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.01", "]"}], ",", "Yellow"}], "}"}]}]}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.975947911874872*^9, 3.9759479732810183`*^9}, {
  3.9759480580831537`*^9, 3.975948099056554*^9}, {3.9759496420727153`*^9, 
  3.97594968642207*^9}, {3.9759499097311316`*^9, 
  3.975949918674861*^9}},ExpressionUUID->"72fed6f1-965b-4218-bc5e-\
8c99230f44a5"],

Cell[BoxData[
 Graphics3DBox[{{{}, {}, 
