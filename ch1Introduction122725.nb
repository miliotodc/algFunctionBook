Cell[CellGroupData[{

Cell["Use built-in z^{1/2} function", "Subsection",
 CellChangeTimes->{{3.976165087596939*^9, 
  3.976165096430127*^9}},ExpressionUUID->"28e9907b-ef72-4655-966f-\
99dcd2127d86"],

Cell[CellGroupData[{

Cell["Illustrate imaginary sheets", "Subsubsection",
 CellChangeTimes->{{3.976176142759912*^9, 
  3.9761761466128807`*^9}},ExpressionUUID->"c1d25ee4-2066-47af-bfc0-\
cc645766b738"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"imag1", "=", " ", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"Im", "[", 
         RowBox[{"z", "^", 
          RowBox[{"{", 
           RowBox[{"1", "/", "2"}], "}"}]}], "]"}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{"r", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.3", "]"}], ",", "Blue"}], "}"}]}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"imag2", "=", " ", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"-", 
         RowBox[{"Im", "[", 
          RowBox[{"z", "^", 
           RowBox[{"{", 
            RowBox[{"1", "/", "2"}], "}"}]}], "]"}]}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{"r", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.3", "]"}], ",", "Red"}], "}"}]}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"imag1", ",", "imag2"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesEdge", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"FaceGrids", "->", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
