Cell[BoxData[{
 RowBox[{"res", "=", 
  RowBox[{"Resultant", "[", 
   RowBox[{"function0032", ",", 
    RowBox[{"D", "[", 
     RowBox[{"function0032", ",", "w"}], "]"}], ",", "w"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"theSingularSet", "=", 
   RowBox[{"Sort", "[", 
    RowBox[{
     RowBox[{"NSolveValues", "[", 
      RowBox[{
       RowBox[{"res", "==", "0"}], ",", "z", ",", 
       RowBox[{"WorkingPrecision", "->", "50"}]}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "@", "#1"}], "<=", " ", 
       RowBox[{"Abs", "@", "#2"}]}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"theSingularSet", "//", "N"}], "\[IndentingNewLine]", 
 RowBox[{"setPrec", "=", 
  RowBox[{"Precision", "@", "theSingularSet"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"theSingularList", "=", 
   RowBox[{"DeleteDuplicates", "[", 
    RowBox[{"theSingularSet", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"#1", "-", "#2"}], "]"}], "<", 
       RowBox[{"10", "^", 
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"setPrec", "-", "10"}], ")"}]}]}]}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
