Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"zPoint", "=", 
   RowBox[{
    RowBox[{"3", "/", "2"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"Pi", " ", 
      RowBox[{"I", "/", "6"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"imagPoint3D", "=", 
   RowBox[{"Graphics3D", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PointSize", "[", "0.02", "]"}], ",", "Green", ",", 
      RowBox[{"Point", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "zPoint"}], ",", 
         RowBox[{"Im", "@", "zPoint"}], ",", 
         RowBox[{"Im", "@", 
          RowBox[{"f1", "[", "zPoint", "]"}]}]}], "}"}]}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"arrowArray", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "@", "z"}], ",", 
           RowBox[{"Im", "@", "z"}], ",", 
           RowBox[{"Im", "@", 
            RowBox[{"f1", "[", "z", "]"}]}]}], "}"}], "/.", 
         RowBox[{"z", "->", 
          RowBox[{
           RowBox[{"3", "/", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"t", " ", "I"}], "]"}]}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"tStart", "+", "0.1"}], ",", "tStop", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"tStop", "-", "tStart"}], ")"}], "/", "50"}]}], "}"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"defArrowG", "=", 
      RowBox[{"Graphics3D", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Arrow", "@", "arrowArray"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"imag1", ",", "imag2", ",", "defArrowG", ",", "imagPoint3D"}],
         "}"}], ",", 
