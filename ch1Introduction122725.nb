Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "evaluate", " ", "the", " ", "symbol", " ", "to", " ", "force", " ", 
    "autoloading"}], "*)"}], 
  RowBox[{
   RowBox[{"Convert`TeX`ExpressionToTeX", ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "modify", " ", "ExpressionToTeX", " ", "so", " ", "that", " ", "it", " ", 
     "blocks", " ", "$TeX", " ", "to", " ", "true"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Unprotect", "[", "Convert`TeX`ExpressionToTeX", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Convert`TeX`ExpressionToTeX", "[", 
      RowBox[{"expr_", ",", 
       RowBox[{"o___", "?", "OptionQ"}]}], "]"}], "/;", 
     RowBox[{"!", 
      RowBox[{"TrueQ", "@", "$TeX"}]}]}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$TeX", "=", "True"}], "}"}], ",", 
      RowBox[{"Convert`TeX`ExpressionToTeX", "[", 
       RowBox[{"expr", ",", "o"}], "]"}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Protect", "[", "Convert`TeX`ExpressionToTeX", "]"}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "modify", " ", "ordplus", " ", "to", " ", "reverse", " ", "the", " ", 
     "order", " ", "of", " ", "polynomials"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TraditionalFormDump`ordplus", "[", 
      RowBox[{"x_", ",", "y_"}], "]"}], "/;", "$TeX"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$TeX", "=", "False"}], "}"}], ",", 
      RowBox[{"Reverse", "@", 
       RowBox[{"TraditionalFormDump`ordplus", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "introduce", " ", "the", " ", "wrapper", " ", "function", " ", 
      "ParameterVariableForm", " ", "to", " ", "allow", " ", "one", " ", "to",
       " ", "specify", " ", "what", " ", "the", "*", "parameter", " ", 
      "variable", " ", "is"}], ",", 
     RowBox[{"that", " ", "is"}], ",", 
     RowBox[{
     "what", " ", "variables", " ", "are", " ", "not", " ", "the", " ", 
      "main", " ", "polynomial", " ", "variable"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Options", "[", "ParameterVariableForm", "]"}], "=", 
     RowBox[{"{", 
      RowBox[{"ParameterVariables", "->", 
       RowBox[{"{", "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Unprotect", "[", "Times", "]"}], ";"}], "\n", 
   RowBox[{"Times", "/:", 
    RowBox[{
     RowBox[{"MakeBoxes", "[", 
      RowBox[{
       RowBox[{"r_Rational", " ", "s_"}], ",", "TraditionalForm"}], "]"}], "/;",
      "$TeX"}], ":=", 
    RowBox[{"RowBox", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"MakeBoxes", "[", 
        RowBox[{"r", ",", "TraditionalForm"}], "]"}], ",", 
       RowBox[{"MakeBoxes", "[", 
        RowBox[{"s", ",", "TraditionalForm"}], "]"}]}], "}"}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Protect", "[", "Times", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"ParameterVariableForm", "/:", 
    RowBox[{"MakeBoxes", "[", 
     RowBox[{
      RowBox[{"ParameterVariableForm", "[", 
       RowBox[{"x_", ",", 
        RowBox[{"opts", ":", 
         RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ",", 
      "TraditionalForm"}], "]"}], ":=", 
    RowBox[{"MakeBoxes", "[", 
     RowBox[{
      RowBox[{"TraditionalForm", "[", 
       RowBox[{"x", ",", "opts"}], "]"}], ",", "TraditionalForm"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"helper", " ", "functions"}], "*)"}], 
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "thecRules", ",", "toPowerBoxes", ",", "parenthesizeRow", ",", 
      "coeffToBoxes", ",", "toMonomialBoxes"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"thecRules", "[", "t_", "]"}], "[", "poly_", "]"}], ":=", 
     RowBox[{"Association", "@", 
      RowBox[{"Sort", "@", 
       RowBox[{"CoefficientRules", "[", 
        RowBox[{"poly", ",", 
         RowBox[{"{", "t", "}"}]}], "]"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toPowerBoxes", "[", "t_", "]"}], ":=", 
     RowBox[{"KeyMap", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MakeBoxes", "[", "#", "]"}], "&"}], "[", 
         RowBox[{"t", "^", "#"}], "]"}], "&"}], "@*", "First"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"parenthesizeRow", "[", 
      RowBox[{"boxes", ":", 
       RowBox[{"{", 
        RowBox[{"b", ":", 
         RowBox[{"Except", "[", "_List", "]"}]}], "}"}]}], "]"}], ":=", 
     RowBox[{"RowBox", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<(\>\"", ",", "b", ",", "\"\<)\>\""}], "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"parenthesizeRow", "[", "boxes_", "]"}], ":=", 
     RowBox[{"RowBox", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<(\>\"", ",", 
        RowBox[{"RowBox", "@", 
         RowBox[{"Flatten", "@", "boxes"}]}], ",", "\"\<)\>\""}], "}"}], 
      "]"}]}], ";", 
    RowBox[{"coeffToBoxes", "//", "ClearAll"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "first", " ", "coeff", " ", "is", " ", "treated", " ", "different"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"coeffToBoxes", "[", "assoc_", "]"}], ":=", 
     RowBox[{
      RowBox[{"MapAt", "[", 
       RowBox[{"MakeBoxes", ",", "1"}], "]"}], "@", 
      RowBox[{
       RowBox[{"MapAt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"Negative", "[", "#", "]"}], ",", "\"\<-\>\"", ",", 
              "\"\<+\>\""}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"MakeBoxes", "[", "#", "]"}], "&"}], "@", 
             RowBox[{"Abs", "@", "#"}]}]}], "}"}], "&"}], ",", 
         RowBox[{"2", ";;"}]}], "]"}], "@", "assoc"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"\[PlusMinus]", "1"}], " ", "are", " ", "specials", " ", 
      "cases"}], ";", 
     RowBox[{"no", " ", "zero", " ", "coeffs"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toMonomialBoxes", "[", 
      RowBox[{"\"\<1\>\"", ",", "coeff_"}], "]"}], ":=", "coeff"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toMonomialBoxes", "[", 
      RowBox[{"power_", ",", 
       RowBox[{"{", 
        RowBox[{"sign_", ",", "coeff_"}], "}"}]}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{"sign", ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"coeff", ",", "\"\< \>\"", ",", "power"}], "}"}], "]"}]}], 
      "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toMonomialBoxes", "[", 
      RowBox[{"power_", ",", "\"\<1\>\""}], "]"}], ":=", "power"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toMonomialBoxes", "[", 
      RowBox[{"power_", ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<-\>\"", ",", "\"\<1\>\""}], "}"}], "]"}]}], "]"}], ":=", 
     RowBox[{"RowBox", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<-\>\"", ",", "power"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"toMonomialBoxes", "[", 
      RowBox[{"power_", ",", "coeff_"}], "]"}], ":=", 
     RowBox[{"RowBox", "[", 
      RowBox[{"{", 
       RowBox[{"coeff", ",", "\"\< \>\"", ",", "power"}], "}"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"aForm", "[", "f_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"RawBoxes", "@", 
        RowBox[{"RowBox", "@", 
         RowBox[{"Riffle", "[", 
          RowBox[{"#", ",", "\"\<+\>\""}], "]"}]}]}], "&"}], "@", 
      RowBox[{
       RowBox[{"KeyValueMap", "[", "toMonomialBoxes", "]"}], "@", 
       RowBox[{
        RowBox[{"Map", "[", "parenthesizeRow", "]"}], "@", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{"KeyValueMap", "[", "toMonomialBoxes", "]"}], "@*", 
           "coeffToBoxes", "@*", 
           RowBox[{"toPowerBoxes", "[", "z", "]"}], "@*", 
           RowBox[{"thecRules", "[", "z", "]"}]}], "]"}], "@", 
         RowBox[{
          RowBox[{"toPowerBoxes", "[", "w", "]"}], "@", 
          RowBox[{
           RowBox[{"thecRules", "[", "w", "]"}], "[", "f", "]"}]}]}]}]}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"aForm2", "[", "f_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"RawBoxes", "@", 
        RowBox[{"RowBox", "@", 
         RowBox[{"Riffle", "[", 
          RowBox[{"#", ",", "\"\<+\>\""}], "]"}]}]}], "&"}], "@", 
      RowBox[{
       RowBox[{"KeyValueMap", "[", "toMonomialBoxes", "]"}], "@", 
       RowBox[{
        RowBox[{"Map", "[", "parenthesizeRow", "]"}], "@", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{"KeyValueMap", "[", "toMonomialBoxes", "]"}], "@*", 
           "coeffToBoxes", "@*", 
           RowBox[{"toPowerBoxes", "[", "c", "]"}], "@*", 
           RowBox[{"thecRules", "[", "c", "]"}]}], "]"}], "@", 
         RowBox[{
          RowBox[{"toPowerBoxes", "[", "z", "]"}], "@", 
          RowBox[{
           RowBox[{"thecRules", "[", "z", "]"}], "[", "f", "]"}]}]}]}]}]}]}], 
