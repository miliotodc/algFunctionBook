Cell[CellGroupData[{

Cell["\<\
Create mIVP of z^{1/2} and contour over f(z,w)=-z+w^2 to illustrate \
analytically-continuous route over branch sheets\
\>", "Subsection",
 CellChangeTimes->{{3.972747243051778*^9, 3.9727472645104938`*^9}, {
  3.975861471911723*^9, 3.97586147446621*^9}, {3.975861694143978*^9, 
  3.9758617013677883`*^9}, {3.97616517212846*^9, 3.9761651802654734`*^9}, {
  3.976176640846918*^9, 
  3.9761766577706914`*^9}},ExpressionUUID->"3b242734-1aab-4224-bbe5-\
0e8ce8c7ad50"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"theFunction", "=", 
    RowBox[{
     RowBox[{"-", "z"}], "+", 
     RowBox[{"w", "^", "2"}]}]}], ";"}], "\n", 
  RowBox[{"(*", "\[IndentingNewLine]", " ", 
   RowBox[{"start", " ", "the", " ", "contour", " ", "at", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "/", "2"}], "]"}]}], ")"}]}], "\[IndentingNewLine]", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z0", "=", 
   RowBox[{"3", "/", "2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"w0", "=", 
    RowBox[{"Sqrt", "[", "z0", "]"}]}], ";"}], "\n", 
  RowBox[{"(*", "\[IndentingNewLine]", " ", 
   RowBox[{
   "revolve", " ", "around", " ", "the", " ", "branch", " ", "sheets", " ", 
    "4", " ", "Pi"}], "\[IndentingNewLine]", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tStart", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", 
    RowBox[{"4", " ", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "\[IndentingNewLine]", " ", 
   RowBox[{"create", " ", "z", 
    RowBox[{"(", "t", ")"}]}], "\[IndentingNewLine]", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Z", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"3", "/", "2"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "\[IndentingNewLine]", " ", 
   RowBox[{"solve", " ", "IVP"}], "\[IndentingNewLine]", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"wDeriv", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"w", "'"}], "[", "t", "]"}], "==", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{"theFunction", ",", "z"}], "]"}], "/", 
           RowBox[{"D", "[", 
            RowBox[{"theFunction", ",", "w"}], "]"}]}], ")"}]}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"Z", "[", "t", "]"}], ",", "t"}], "]"}]}], ")"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"w", "->", 
         RowBox[{"w", "[", "t", "]"}]}], ",", 
        RowBox[{"z", "->", 
         RowBox[{"Z", "[", "t", "]"}]}]}], "}"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"theSol", "=", 
    RowBox[{"NDSolveValue", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"wDeriv", ",", 
        RowBox[{
         RowBox[{"w", "[", "tStart", "]"}], "==", "w0"}]}], "}"}], ",", "w", 
      ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tStart", ",", "tEnd"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"mPlot", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "z"}], ",", 
         RowBox[{"Im", "@", "z"}], ",", 
         RowBox[{"Re", "@", 
          RowBox[{"theSol", "[", "t", "]"}]}]}], "}"}], "/.", " ", 
       RowBox[{"z", "->", 
        RowBox[{"Z", "[", "t", "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tStart", ",", "tEnd"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.01", "]"}], ",", "Black"}], "}"}]}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"real1", ",", "real2", ",", "mPlot"}], "}"}], ",", 
   RowBox[{"AxesEdge", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"FaceGrids", "->", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
        "}"}]}], "}"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<x\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<y\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Re(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
       "]"}]}], "}"}]}], ",", 
   RowBox[{"FaceGridsStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "Dotted"}], "]"}]}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"BoxRatios", "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9513218377657285`*^9, 3.9513218377657285`*^9}, {
   3.972747275100613*^9, 3.972747344578023*^9}, {3.9758615392458487`*^9, 
   3.975861585375703*^9}, {3.9761767050742726`*^9, 3.9761767555873346`*^9}, {
   3.9761772709335766`*^9, 3.976177273983605*^9}, 3.9761773169220295`*^9, {
   3.9761773706042747`*^9, 3.976177440529009*^9}},
 CellLabel->
  "In[133]:=",ExpressionUUID->"422332f5-4b74-48ce-b90e-d79dfcf5eccf"],

