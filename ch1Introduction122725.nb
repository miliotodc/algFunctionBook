Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f1", "[", "z_", "]"}], ":=", 
   RowBox[{"Sqrt", "[", "z", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"imag1", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"Im", "@", 
         RowBox[{"f1", "[", "z", "]"}]}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{"r", " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.3", "]"}], ",", "Blue"}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "3"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"imag2", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "z"}], ",", 
         RowBox[{"Im", "@", "z"}], ",", 
         RowBox[{"-", 
          RowBox[{"Im", "@", 
           RowBox[{"f1", "[", "z", "]"}]}]}]}], "}"}], "/.", 
       RowBox[{"z", "->", 
        RowBox[{"r", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.3", "]"}], ",", "Red"}], "}"}]}], ",", 
      RowBox[{"PlotRange", "->", "3"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"imContour", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"Im", "@", 
         RowBox[{"f1", "[", "z", "]"}]}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{
        RowBox[{"3", "/", "2"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"Pi", "/", "6"}], ",", 
       RowBox[{
        RowBox[{"2", " ", "Pi"}], "+", 
        RowBox[{"Pi", "/", "2"}]}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Thickness", "[", "0.01", "]"}], ",", "Yellow"}], "}"}]}], 
     ",", 
     RowBox[{"PlotRange", "->", "3"}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.975940806362733*^9, 3.9759408320159845`*^9}, {
