Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"theConst", "=", 
     RowBox[{
      RowBox[{"2", "/", "3"}], "+", 
      RowBox[{"\[ImaginaryI]", "/", "4"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"theFunction", "=", 
     RowBox[{
      RowBox[{"z", " ", 
       RowBox[{"w", "^", "4"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"theConst", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{
              RowBox[{"theConst", "\[Conjugate]"}], "^", "2"}], " ", 
             RowBox[{"w", "^", "2"}]}]}], ")"}]}], ")"}], "^", "4"}]}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"theConst", "\[Conjugate]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"theConst", "^", "2"}], "-", 
           RowBox[{"w", "^", "2"}]}], ")"}]}], ")"}], "^", "4"}]}]}], ";"}], 
   " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pSeries", "=", 
     RowBox[{"w", "/.", 
      RowBox[{"AsymptoticSolve", "[", 
       RowBox[{
        RowBox[{"theFunction", "==", "0"}], ",", "w", ",", 
        RowBox[{"{", 
         RowBox[{"z", ",", "0", ",", "5"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
