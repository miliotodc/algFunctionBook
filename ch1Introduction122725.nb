Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"theSingularSet", "=", 
    RowBox[{"Sort", "[", 
     RowBox[{
      RowBox[{"z", "/.", 
       RowBox[{"NSolve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Simplify", "@", "res"}], "\[Equal]", "0"}], ",", "z", ",", 
         RowBox[{"WorkingPrecision", "\[Rule]", "workingPrecision"}]}], 
        "]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "@", "#1"}], "<=", " ", 
        RowBox[{"Abs", "@", "#2"}]}], "&"}]}], "]"}]}], ";"}]}]], "Input",
