Cell[CellGroupData[{

Cell["\<\
Use exponential form of z^{1/2}:  The same branch-cut discontinuity is \
observed in the exponential form\
\>", "Subsection",
 CellChangeTimes->{{3.9758616205112934`*^9, 3.9758616263252096`*^9}, {
  3.9761651168124886`*^9, 3.9761651333401613`*^9}, {3.976176544429967*^9, 
  3.9761765576434946`*^9}},ExpressionUUID->"e2da7b3b-ebff-4d3a-be4c-\
f7c1163b852c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"squareRoot", "[", 
    RowBox[{"z_", ",", "k_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "z", "]"}], "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "2"}], ")"}]}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"I", "/", "2"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Arg", "[", "z", "]"}], "+", 
        RowBox[{"2", " ", "k", " ", "Pi"}]}], ")"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sReal1", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "z"}], ",", 
         RowBox[{"Im", "@", "z"}], ",", 
         RowBox[{"Im", "[", 
          RowBox[{"squareRoot", "[", 
           RowBox[{"z", ",", "0"}], "]"}], "]"}]}], "}"}], "/.", " ", 
       RowBox[{"z", "->", 
        RowBox[{"r", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0.001", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.25", "]"}], ",", "Red"}], "}"}]}]}], 
     "]"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "sheet", " ", "2"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sReal2", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", "z"}], ",", 
         RowBox[{"Im", "@", "z"}], ",", 
         RowBox[{"Im", "[", 
          RowBox[{"squareRoot", "[", 
           RowBox[{"z", ",", "1"}], "]"}], "]"}]}], "}"}], "/.", " ", 
       RowBox[{"z", "->", 
        RowBox[{"r", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "t"}], "]"}]}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0.001", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.25", "]"}], ",", "Blue"}], "}"}]}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Show", " ", "plots"}], "*)"}]}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"sReal1", ",", "sReal2"}], "}"}], ",", 
   RowBox[{"AxesEdge", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"FaceGrids", "->", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
        "}"}]}], "}"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<x\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<y\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Im(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
       "]"}]}], "}"}]}], ",", 
   RowBox[{"FaceGridsStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "Dotted"}], "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9513217533674617`*^9, 3.9513217533674617`*^9}, {
  3.95132275343577*^9, 3.9513228138064284`*^9}, {3.9513232373407373`*^9, 
