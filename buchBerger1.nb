         RowBox[{
          RowBox[{"{", 
           RowBox[{"n", ",", "genSetLen"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"genSetLen", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<genSequence: \>\"", ",", "genSequence"}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"k", "=", "1"}], ",", 
         RowBox[{"k", "\[LessEqual]", 
          RowBox[{"Length", "@", "genSequence"}]}], ",", 
         RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Selecting: S\>\"", ",", 
            RowBox[{"genSequence", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Generateing s-poly with bases: \>\"", ",", 
            RowBox[{"genSet", "[", 
             RowBox[{"[", 
              RowBox[{"genSequence", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "1"}], "]"}], "]"}], "]"}], "]"}], ",", 
            "\"\< and \>\"", ",", 
            RowBox[{"genSet", "[", 
             RowBox[{"[", 
              RowBox[{"genSequence", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "2"}], "]"}], "]"}], "]"}], "]"}]}], "]"}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"sPoly", "=", 
           RowBox[{
            RowBox[{"sFun", "[", 
             RowBox[{
              RowBox[{"genSet", "[", 
               RowBox[{"[", 
                RowBox[{"genSequence", "[", 
                 RowBox[{"[", 
                  RowBox[{"k", ",", "1"}], "]"}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"genSet", "[", 
               RowBox[{"[", 
                RowBox[{"genSequence", "[", 
                 RowBox[{"[", 
                  RowBox[{"k", ",", "2"}], "]"}], "]"}], "]"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "//", "Expand"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{"\"\<sPoly is: \>\"", ",", "sPoly"}], "]"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"sPoly", "=!=", "0"}], ",", "\[IndentingNewLine]", 
            RowBox[{"(*", "\[IndentingNewLine]", " ", 
             RowBox[{
             "check", " ", "if", " ", "reduction", " ", "is", " ", 
              "completly", " ", "reduced"}], "\[IndentingNewLine]", "*)"}], 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{
              "\"\<Checking if \>\"", ",", "sPoly", ",", 
