       RowBox[{"f1", "[", 
        RowBox[{"x", ",", "y"}], "]"}], ",", 
       RowBox[{"f2", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"genSetLen", "=", 
