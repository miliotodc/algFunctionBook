      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", 
        RowBox[{"genSetLen", "-", "1"}]}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"genSetPrime", "=", "genSet"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"notAdded", "=", "True"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"index", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
