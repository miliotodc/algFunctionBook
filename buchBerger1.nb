              "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"reduced", "=", "False"}], ";", "\[IndentingNewLine]", 
             RowBox[{"reduceFlag", "=", "False"}], ";", "\[IndentingNewLine]", 
             RowBox[{"For", "[", 
              RowBox[{
               RowBox[{"j", "=", "1"}], ",", 
               RowBox[{"j", "\[LessEqual]", 
                RowBox[{"Length", "@", "genSet"}]}], ",", 
               RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"Print", "[", 
                 RowBox[{"\"\<this is j: \>\"", ",", "j"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"!", "reduceFlag"}], ",", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"pModTemp", "=", 
                    RowBox[{
                    RowBox[{"getPmodG", "[", 
                    RowBox[{"sPoly", ",", 
                    RowBox[{"{", 
                    RowBox[{"genSet", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "}"}], ",", "False", ",", 
                    "50"}], "]"}], "//", "Expand"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Print", "[", 
                    RowBox[{"\"\<     Checking reducible by \>\"", ",", 
                    RowBox[{"genSet", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ";", 
