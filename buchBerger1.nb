Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"getPmodG", "[", 
      RowBox[{"poly_", ",", "g_", ",", "stats_", ",", "maxD_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "divisorIndex", ",", "quotientSequence", ",", "errorStats", ",", 
         "ltDivisors", ",", "expDivisorList", ",", "quotients", ",", 
         "currentDivisor", ",", "currentRemainder", ",", "ltr", ",", "p", ",",
          "divisors", ",", "index", ",", "noneLeft", ",", "ltd", ",", "pRed", 
         ",", "qVal", ",", "pPos", ",", "eList", ",", "mVal", ",", "pVal", 
         ",", "result", ",", "totalDivisors", ",", "cRules", ",", 
         "divisorIndexList"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"totalDivisors", "=", 
         RowBox[{"Length", "@", "g"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"p", "=", "poly"}], ";", "\[IndentingNewLine]", 
        RowBox[{"divisors", "=", "g"}], ";", "\[IndentingNewLine]", " ", 
        RowBox[{"divisorIndex", "=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"quotientSequence", "=", 
         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", "\[IndentingNewLine]", " ", 
         RowBox[{
         "get", " ", "leading", " ", "terms", " ", "of", " ", "all", " ", 
          "divisors"}], "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"errorStats", "=", "stats"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ltDivisors", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"MonomialList", "[", 
             RowBox[{"#", ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "y"}], "}"}], ",", "Lexicographic"}], 
             "]"}]}], "&"}], "/@", "divisors"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", "\[IndentingNewLine]", 
         RowBox[{"get", " ", "monomial", " ", "exponent", " ", "matrix"}], 
         "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"cRules", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"CoefficientRules", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "y"}], "}"}], ",", 
               "\"\<Lexicographic\>\""}], "]"}], "&"}], "/@", " ", 
            "divisors"}], ")"}], "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "All", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Print", "[", "cRules", "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{"\"\<ltDivisors: \>\"", ",", "ltDivisors"}], "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", "\[IndentingNewLine]", " ", 
         RowBox[{
         "get", " ", "exponent", " ", "on", " ", "x", " ", "of", " ", "each", 
          " ", "leading", " ", "term", " ", "in", " ", "divisor", " ", 
          "list"}], "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"expDivisorList", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Exponent", "[", 
            RowBox[{"#", ",", "x"}], "]"}], "&"}], "/@", " ", 
          "ltDivisors"}]}], ";", "\n", "\[IndentingNewLine]", 
        RowBox[{"quotients", "=", 
         RowBox[{"Table", "[", 
          RowBox[{"0", ",", 
           RowBox[{"{", "totalDivisors", "}"}]}], "]"}]}], ";", "\n", 
        RowBox[{"currentDivisor", "=", 
         RowBox[{"divisors", "[", 
          RowBox[{"[", "divisorIndex", "]"}], "]"}]}], ";", "\n", 
        RowBox[{"currentRemainder", "=", "p"}], ";", "\[IndentingNewLine]", 
        RowBox[{
        "(*", "\[IndentingNewLine]", " ", "\[IndentingNewLine]", "*)"}], "\n", 
        RowBox[{"ltr", "=", 
         RowBox[{"First", "@", 
          RowBox[{"MonomialList", "[", 
           RowBox[{"p", ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y"}], "}"}], ",", "Lexicographic"}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"index", "=", "0"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"noneLeft", "=", "False"}], ";", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"!", "noneLeft"}], " ", "&&", " ", 
           RowBox[{"index", "<", "maxD"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"index", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"ltd", "=", 
            RowBox[{"First", "@", 
             RowBox[{"MonomialList", "[", 
              RowBox[{"currentDivisor", ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "y"}], "}"}], ",", "Lexicographic"}], 
              "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{
               "\"\<leading term of divisor \>\"", ",", "currentDivisor", 
                ",", "\"\< : \>\"", ",", "ltd"}], "]"}], ";"}]}], 
            "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"pRed", "=", 
            RowBox[{"PolynomialReduce", "[", 
             RowBox[{"ltr", ",", "ltd", ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "y"}], "}"}], ",", 
              RowBox[{"MonomialOrder", "\[Rule]", "Lexicographic"}]}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{
               "\"\<pRed: \>\"", ",", "pRed", ",", "\"\< : \>\"", ",", 
                "index"}], "]"}], ";"}]}], " ", "\[IndentingNewLine]", "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"pRed", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "===", "0"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", "\[IndentingNewLine]", 
              RowBox[{
              "leading", " ", "term", " ", "of", " ", "current", " ", 
               "divisor", " ", "divides", " ", "remainder"}], 
              "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"qVal", "=", 
               RowBox[{"ltr", "/", "ltd"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{"\"\<qVal: \>\"", ",", "qVal"}], "]"}], ";"}]}], 
               " ", "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"quotients", "[", 
                RowBox[{"[", "divisorIndex", "]"}], "]"}], "+=", "qVal"}], 
              ";", "\[IndentingNewLine]", 
              RowBox[{"currentRemainder", "=", 
               RowBox[{"currentRemainder", "-", 
                RowBox[{"qVal", " ", "currentDivisor"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{"\"\<currentRemainder: \>\"", ",", 
                   RowBox[{"currentRemainder", "//", "Expand"}]}], "]"}], 
                 ";"}]}], " ", "\[IndentingNewLine]", "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"ltr", "=", 
               RowBox[{"First", "@", 
                RowBox[{"MonomialList", "[", 
                 RowBox[{"currentRemainder", ",", 
                  RowBox[{"{", 
                   RowBox[{"x", ",", "y"}], "}"}], ",", "Lexicographic"}], 
                 "]"}]}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<leading term of current remainder: \>\"", ",", "ltr"}],
                   "]"}], ";"}]}], " ", "\[IndentingNewLine]", "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"quotientSequence", ",", "divisorIndex"}], "]"}], 
              ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
             RowBox[{"(*", "\[IndentingNewLine]", " ", 
              RowBox[{
              "leading", " ", "term", " ", "of", " ", "current", " ", 
               "divisor", " ", "does", " ", "not", " ", "divide", " ", 
               "current", " ", "remainder", "\[IndentingNewLine]", " ", 
               "search", " ", "for", " ", "a", " ", "new", " ", "divisor"}], 
              "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{"Style", "[", 
                   RowBox[{"\"\<pRed not equal to 0\>\"", ",", "Red"}], "]"}],
                   "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pRed", "=", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"PolynomialReduce", "[", 
                   RowBox[{"ltr", ",", "#", ",", 
                    RowBox[{"{", 
                    RowBox[{"x", ",", "y"}], "}"}], ",", 
                    RowBox[{"MonomialOrder", "\[Rule]", "Lexicographic"}]}], 
                   "]"}], "&"}], "/@", "ltDivisors"}], ")"}]}], " ", ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<pRed check of all divisors: \>\"", ",", "pRed"}], 
                  "]"}], ";"}]}], " ", "\[IndentingNewLine]", "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pPos", "=", 
               RowBox[{
                RowBox[{"Position", "[", 
                 RowBox[{"pRed", ",", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"a_", ",", "b_"}], "}"}], "/;", 
                   RowBox[{"b", "===", "0"}]}]}], "]"}], "//", "Flatten"}]}], 
              ";", "\[IndentingNewLine]", 
              RowBox[{"(*", "\[IndentingNewLine]", 
               RowBox[{
               "pPos", " ", "is", " ", "location", " ", "in", " ", "divisor", 
                " ", "list", " ", "where", " ", "lt", " ", "matches", 
                "\[IndentingNewLine]", "  ", "now", " ", "create", " ", "a", 
                " ", "list", " ", 
                RowBox[{"{", 
                 RowBox[{"index", ",", "divisor"}], "}"}], " ", "of", " ", 
                "these", " ", "divisors", " ", "with", " ", "index", " ", 
                "into", " ", "the", " ", "divisor", " ", "list"}], 
               "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
              RowBox[{"divisorIndexList", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"#", ",", 
                   RowBox[{"ltDivisors", "[", 
                    RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", " ",
                 "pPos"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<divisorIndexList: \>\"", ",", "divisorIndexList"}], 
                  "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
              "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  RowBox[{
                   RowBox[{"Style", "[", 
                    RowBox[{"\"\<pPos: \>\"", ",", "Blue"}], "]"}], ",", 
                   "pPos"}], "]"}], ";"}]}], " ", "\[IndentingNewLine]", 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "@", "pPos"}], ">", "0"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"(*", "\[IndentingNewLine]", " ", 
                 RowBox[{
                  RowBox[{"found", " ", "applicable", " ", "divisors"}], ",", 
                  " ", 
                  RowBox[{
                  "choose", " ", "one", " ", "with", " ", "greatest", " ", 
                   "exponent", " ", "on", " ", "x"}]}], "\[IndentingNewLine]",
                  "*)"}], "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{"errorStats", ",", "\[IndentingNewLine]", "  ", 
                   RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{"Style", "[", 
                    RowBox[{"\"\<Found a new divisor: \>\"", ",", "Purple"}], 
                    "]"}], "]"}], ";"}]}], " ", "\[IndentingNewLine]", "]"}], 
                 ";", "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Length", "@", "pPos"}], ">", "1"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                    RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{
                    "\"\<Found multiple divisors: \>\"", ",", "Bold", ",", 
                    "Black"}], "]"}], ",", 
                    RowBox[{"ltDivisors", "[", 
                    RowBox[{"[", "pPos", "]"}], "]"}]}], "]"}], ";"}]}], " ", 
                    "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
                    RowBox[{"eList", "=", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "x"}], "]"}], "&"}], "/@", " ", 
                    RowBox[{"divisorIndexList", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{"\"\<eList for x: \>\"", ",", "eList"}], "]"}], 
                    ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
                    "\[IndentingNewLine]", " ", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "@", "eList"}], "\[Equal]", "0"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{
                    "Print", "[", 
                    "\"\<x divisors not found, searching for y-divisors\>\"", 
                    "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"eList", "=", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Exponent", "[", 
                    RowBox[{"#", ",", "y"}], "]"}], "&"}], "/@", " ", 
                    RowBox[{"divisorIndexList", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], ";"}]}], 
                    "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
                    "\[IndentingNewLine]", 
                    RowBox[{"mVal", "=", 
                    RowBox[{"Max", "@", "eList"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"pVal", "=", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Position", "[", 
                    RowBox[{"eList", ",", "mVal"}], "]"}], "//", "Flatten"}], 
                    "//", "First"}]}], ";", "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{"\"\<pVal: \>\"", ",", "Black", ",", "Bold"}], 
                    "]"}], ",", "pVal"}], "]"}], ";"}]}], 
                    "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
                    RowBox[{"divisorIndex", "=", 
                    RowBox[{"divisorIndexList", "[", 
                    RowBox[{"[", 
                    RowBox[{"pVal", ",", "1"}], "]"}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"currentDivisor", "=", 
                    RowBox[{"divisors", "[", 
                    RowBox[{"[", "divisorIndex", "]"}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{
                    "\"\<Updating current divisor: \>\"", ",", 
                    "currentDivisor"}], "]"}], ";"}]}], "\[IndentingNewLine]",
                     "]"}], ";"}], "\[IndentingNewLine]", ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"(*", "\[IndentingNewLine]", 
                    RowBox[{
                    "only", " ", "one", " ", "divisor", " ", "found"}], 
                    "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"pPos", "=", 
                    RowBox[{"pPos", "//", "First"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"currentDivisor", "=", 
                    RowBox[{"divisors", "[", 
                    RowBox[{"[", "pPos", "]"}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{"errorStats", ",", "\[IndentingNewLine]", " ", 
                    RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{
                    RowBox[{"Style", "[", 
                    RowBox[{
                    "\"\<Found only one new divisor\>\"", ",", "Magenta"}], 
                    "]"}], ",", "currentDivisor"}], "]"}], ";"}]}], " ", 
                    "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
                    RowBox[{"divisorIndex", "=", "pPos"}], ";"}]}], 
                  "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"quotientSequence", ",", "divisorIndex"}], "]"}], 
                 ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
                RowBox[{"(*", " ", "\[IndentingNewLine]", " ", 
                 RowBox[{"no", " ", "more", " ", "divisors"}], 
                 "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"noneLeft", "=", "True"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"result", "=", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"quotients", ".", "divisors"}], "+", 
                    "currentRemainder"}], ")"}], "//", "Expand"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"If", "[", 
                  RowBox[{"errorStats", ",", "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"Print", "[", 
                    RowBox[{
                    "\"\<No more divisors.  Solution is: [\>\"", ",", 
                    "quotients", ",", "\"\<,\>\"", ",", 
                    RowBox[{"currentRemainder", "//", "Expand"}], ",", 
                    "\"\<],\>\"", ",", "quotientSequence", ",", "\"\<:\>\"", 
                    ",", 
                    RowBox[{"result", "===", "p"}]}], "]"}], ";"}]}], 
                  "\[IndentingNewLine]", "]"}], ";"}]}], 
               "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", 
            "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"index", "\[Equal]", "maxD"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0", ",", "index"}], 
           "}"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"quotients", "//", "Expand"}], ",", "currentRemainder", 
            ",", "quotientSequence", ",", 
            RowBox[{"result", "===", "p"}], ",", "index"}], "}"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
