       RowBox[{"51", ",", "100"}], "}"}], "]"}]}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"sFun", "[", 
      RowBox[{"p1_", ",", "p2_", ",", "vars_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lt1", ",", "lt2"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lt1", "=", 
         RowBox[{"First", "[", 
          RowBox[{"MonomialList", "[", 
           RowBox[{"p1", ",", "vars", ",", "Lexicographic"}], "]"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"lt2", "=", 
         RowBox[{"First", "[", 
          RowBox[{"MonomialList", "[", 
           RowBox[{"p2", ",", "vars", ",", "Lexicographic"}], "]"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"PolynomialLCM", "[", 
            RowBox[{"lt1", ",", "lt2"}], "]"}], "/", "lt1"}], " ", "p1"}], 
         "-", 
         RowBox[{
          RowBox[{
           RowBox[{"PolynomialLCM", "[", 
            RowBox[{"lt1", ",", "lt2"}], "]"}], "/", "lt2"}], " ", 
          "p2"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
