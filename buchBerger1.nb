Cell[BoxData[
 RowBox[{
  RowBox[{"pModCheck", "[", "dseq_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"divList", ",", "i", ",", "currentVal", ",", "dSeq"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"divList", "=", 
      RowBox[{"{", 
       RowBox[{"dSeq", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "@", "dSeq"}], ">", "1"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"i", "=", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"currentVal", "=", 
         RowBox[{"dSeq", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"i", "<=", 
           RowBox[{"Length", "@", "dSeq"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"dSeq", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "\[NotEqual]", "currentVal"}], 
             ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"AppendTo", "[", 
               RowBox[{"divList", ",", 
                RowBox[{"dSeq", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"currentVal", "=", 
               RowBox[{"dSeq", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ";"}]}], 
            "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"i", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
        ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "@", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Tally", "@", "divList"}], ")"}], "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"#", ">", "1"}], "&"}]}], "]"}]}], ">", "0"}], ",", 
       "\[IndentingNewLine]", "True", "\[IndentingNewLine]", ",", 
       "\[IndentingNewLine]", "False"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
