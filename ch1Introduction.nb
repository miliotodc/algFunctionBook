Cell["\<\
The same branch-cut discontinuity is observed over the real sheets\
\>", "Text",
 CellChangeTimes->{{3.9761762386663575`*^9, 3.976176331055395*^9}, {
  3.9761764731359997`*^9, 
  3.9761764890676837`*^9}},ExpressionUUID->"67158b99-9201-4a95-a2cd-\
b6b6b0715371"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"realContour", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"Re", "[", 
         RowBox[{"z", "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], "]"}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "t"}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", 
       RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Yellow"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"real1", ",", "real2", ",", "realContour"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesEdge", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"FaceGrids", "->", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
        "}"}]}], "}"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<x\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<y\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Im(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
       "]"}]}], "}"}]}], ",", 
   RowBox[{"FaceGridsStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "Dotted"}], "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9761761876277523`*^9, 3.976176227761772*^9}, {
  3.97617644908212*^9, 3.976176466308754*^9}},
