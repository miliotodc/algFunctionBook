Cell[CellGroupData[{

Cell["\<\
Illustrate contour over z^{1/2} using default definition of z^{1/2} \
encounters branch-cut\
\>", "Subsubsection",
 CellChangeTimes->{{3.9761760046729193`*^9, 
  3.9761760318027587`*^9}},ExpressionUUID->"67132850-3e4e-454d-a1f4-\
69db33d29b51"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"  ", 
  RowBox[{
   RowBox[{
    RowBox[{"contour1", "=", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Re", "@", "z"}], ",", 
          RowBox[{"Im", "@", "z"}], ",", 
          RowBox[{"Im", "[", 
           RowBox[{"z", "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}]}], "]"}]}], "}"}], "/.", 
        RowBox[{"z", "->", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "t"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", 
         RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Yellow"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b1", ",", "b2", ",", "contour1"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesEdge", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"FaceGrids", "->", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", 
             RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", 
             RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
          "}"}]}], "}"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
        ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<y\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
        ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Im(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
         "]"}]}], "}"}]}], ",", 
     RowBox[{"FaceGridsStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Black", ",", "Dotted"}], "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9761759982812023`*^9, 3.9761759993592806`*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"3637c2c8-c78b-41b9-b77f-f5864c67e568"],

