Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"expList", "=", 
     RowBox[{"Exponent", "[", 
      RowBox[{
       RowBox[{"pSeries", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", "z", ",", "List"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coefList", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{"pSeries", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", "z", ",", "#"}], "]"}], "&"}], 
      "/@", " ", "expList"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"theLCM", "=", 
     RowBox[{"LCM", "@@", 
      RowBox[{"(", 
       RowBox[{"Denominator", "@", "expList"}], ")"}]}]}], ";"}], "\n", " ", 
   RowBox[{"numerators", "=", 
    RowBox[{"theLCM", " ", "expList"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rootTestTable", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"numerators", "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"coefList", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "]"}], "^", 
              RowBox[{"(", 
               RowBox[{"4", "/", 
                RowBox[{"numerators", "[", 
                 RowBox[{"[", "k", "]"}], "]"}]}], ")"}]}], ")"}]}], ",", 
           "25"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"k", ",", "15", ",", 
         RowBox[{"Length", "@", "coefList"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"lp1", "=", 
    RowBox[{"ListPlot", "[", 
     RowBox[{"rootTestTable", ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"PointSize", "[", "0.005", "]"}], "}"}]}], ",", 
      RowBox[{"AxesOrigin", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellLabel->"In[44]:=",ExpressionUUID->"e82fcd33-3cf4-495b-aa33-972eaa9f6f24"],

