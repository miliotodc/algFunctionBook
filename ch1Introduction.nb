3d0bbdd4c0c3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gPoint3D", "=", 
   RowBox[{"Graphics3D", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PointSize", "[", "0.02", "]"}], ",", "Green", ",", 
      RowBox[{"Point", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "@", 
          RowBox[{"Z", "[", "tStart", "]"}]}], ",", 
         RowBox[{"Im", "@", 
          RowBox[{"Z", "[", "tStart", "]"}]}], ",", 
         RowBox[{"Re", "@", 
          RowBox[{"theSol", "[", "tStart", "]"}]}]}], "}"}]}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ppReal", "=", 
      RowBox[{"ParametricPlot3D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "@", "z"}], ",", 
           RowBox[{"Im", "@", "z"}], ",", 
           RowBox[{"Re", "@", 
            RowBox[{"theSol", "[", "t", "]"}]}]}], "}"}], "/.", " ", 
         RowBox[{"z", "->", 
          RowBox[{"Z", "[", "t", "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "tStart", ",", "tStop"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", "0.01", "]"}], ",", "Black"}], "}"}]}]}],
        "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"arrowArray", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "@", "z"}], ",", 
           RowBox[{"Im", "@", "z"}], ",", 
           RowBox[{"Re", "@", 
            RowBox[{"theSol", "[", "t", "]"}]}]}], "}"}], "/.", 
         RowBox[{"z", "->", 
          RowBox[{"Z", "[", "t", "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"tStart", "+", "0.1"}], ",", "tStop", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"tStop", "-", "tStart"}], ")"}], "/", "50"}]}], "}"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"arrowG", "=", 
      RowBox[{"Graphics3D", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.005", "]"}], ",", 
         RowBox[{"Arrow", "@", "arrowArray"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"real1", ",", "real2", ",", "arrowG", ",", "gPoint3D"}], 
        "}"}], ",", 
       RowBox[{"AxesEdge", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
       RowBox[{"FaceGrids", "->", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", 
               RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], 
             ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", 
               RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], 
              "}"}]}], "}"}]}], "}"}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Re[z]\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
           "]"}], ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Im[z]\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
           "]"}], ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Re(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
           "]"}]}], "}"}]}], ",", 
       RowBox[{"FaceGridsStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", "Dotted"}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
