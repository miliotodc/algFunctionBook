 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Z", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"3", "/", "2"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "\[IndentingNewLine]", " ", 
   RowBox[{"solve", " ", "IVP"}], "\[IndentingNewLine]", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"wDeriv", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"w", "'"}], "[", "t", "]"}], "==", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{"theFunction", ",", "z"}], "]"}], "/", 
           RowBox[{"D", "[", 
            RowBox[{"theFunction", ",", "w"}], "]"}]}], ")"}]}], " ", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"Z", "[", "t", "]"}], ",", "t"}], "]"}]}], ")"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"w", "->", 
         RowBox[{"w", "[", "t", "]"}]}], ",", 
        RowBox[{"z", "->", 
         RowBox[{"Z", "[", "t", "]"}]}]}], "}"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
