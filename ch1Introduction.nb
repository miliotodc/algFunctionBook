Cell["\<\
Notice in the following code how a contour over the default definition of \
z^{1/2} starting at z=1 on the blue sheet and encounters the default \
branch-cut at the negative real axis and abruptly drops down to the lower \
blue sheet of the branch rather than analyticallly-continuing onto the red \
sheet.\
\>", "Text",
 CellChangeTimes->{{3.9761762386663575`*^9, 
  3.976176331055395*^9}},ExpressionUUID->"e624d330-39b1-4ad2-ad36-\
6152b7ea6764"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"imagContour", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "@", "z"}], ",", 
        RowBox[{"Im", "@", "z"}], ",", 
        RowBox[{"Im", "[", 
         RowBox[{"z", "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], "]"}]}], "}"}], "/.", 
      RowBox[{"z", "->", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "t"}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", 
       RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Yellow"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"imag1", ",", "imag2", ",", "imagContour"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesEdge", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"FaceGrids", "->", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.5"}], ",", "0", ",", "0.5", ",", "1"}], "}"}]}], 
        "}"}]}], "}"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<x\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<y\>\"", ",", "14", ",", "Bold", ",", "Black"}], "]"}], 
      ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Im(w)\>\"", ",", "14", ",", "Bold", ",", "Black"}], 
       "]"}]}], "}"}]}], ",", 
   RowBox[{"FaceGridsStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "Dotted"}], "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9761761876277523`*^9, 
  3.976176227761772*^9}},ExpressionUUID->"7b59c2e5-ea73-469b-9a84-\
4ede8a6dc93f"],

